# Core runtime
NODE_ENV=development
PORT=3001

# Database / cache
# Local Postgres (adjust user/password/db to your install)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?schema=public
REDIS_URL=redis://localhost:6379

# JWT (RS256) - replace with your generated PEM keys
# Generate with:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
PASTE_YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"

# Optional app settings
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dev super admin (after `npm --workspace backend run prisma:seed`)
# SUPER_ADMIN_EMAIL=super@reos.dev
# SUPER_ADMIN_PASSWORD=ChangeMe123!
