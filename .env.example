# Core runtime
NODE_ENV=development
PORT=3001

# Database / cache
# Local Postgres (adjust user/password/db to your install)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?schema=public
# Required in production for BullMQ queues and shared TTL caches.
REDIS_URL=redis://localhost:6379

# Docker Compose staging defaults (replace password before use)
POSTGRES_DB=reos
POSTGRES_USER=reos
POSTGRES_PASSWORD=change-me
API_PORT=3001
FRONTEND_PORT=3000

# Database backups (P0-6) — used by scripts/db-backup.sh and the compose "backup" service
BACKUP_RETENTION_DAYS=7
# Optional offsite mirror, e.g. s3://my-bucket/reos-backups (requires aws CLI)
BACKUP_S3_BUCKET=

# JWT (RS256) - replace with your generated PEM keys
# Generate with:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
PASTE_YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"

# Optional app settings
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Billing launch mode
# assisted = record plan requests and handle payment/GST invoices offline.
# live = use the configured payment provider checkout flow.
BILLING_LAUNCH_MODE=assisted
PAYMENT_PROVIDER=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Observability (P0-8)
# Structured request logs: set to "json" outside dev so log shippers
# (CloudWatch/Loki/Datadog) can parse newline-delimited JSON from stdout.
LOG_FORMAT=text
# Error tracking: leave SENTRY_DSN empty to disable (safe no-op). When set,
# server-side faults (5xx) are forwarded to Sentry with request context.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
APP_RELEASE=

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_REOS_BILLING_MODE=assisted

# Dev super admin (after `npm --workspace backend run prisma:seed`)
# SUPER_ADMIN_EMAIL=super@reos.dev
# SUPER_ADMIN_PASSWORD=ChangeMe123!
